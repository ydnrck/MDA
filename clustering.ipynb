    "# exploratory PCA to see if cluster analysis on principal components is feasible\n",
    "\n",
    "pca_full = PCA(random_state=RANDOM_STATE)\n",
    "pca_scores_full = pca_full.fit_transform(X_clust)\n",
    "\n",
    "pca_var = pd.DataFrame({\"pc\": np.arange(1, len(pca_full.explained_variance_ratio_) + 1),\n",
    "                        \"explained_variance\": pca_full.explained_variance_ratio_,\n",
    "                        \"cumulative_variance\": np.cumsum(pca_full.explained_variance_ratio_)})\n",
    "\n",
    "display(pca_var.round(3))\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "sns.lineplot(data=pca_var, x=\"pc\", y=\"cumulative_variance\", marker=\"o\")\n",
    "plt.axhline(0.80, linestyle=\"--\", color=\"grey\")\n",
    "plt.xlabel(\"number of principal components\")\n",
    "plt.ylabel(\"cumulative explained variance\")\n",
    "plt.title(\"PCA plot for clustering features\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "57b3ee49-be6d-439e-85c5-93a1513b2fa6",
   "metadata": {},
   "source": [
    "From the PCA, we see that to run cluster analysis on principal components (if needed), we must retain at least first 5 principal components to retain 80%+ of the variance.   "
   ]
