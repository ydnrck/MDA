   "source": [
    "# making daily summaries for each site\n",
    "\n",
    "site_day = (site_time.groupby([\"site_id\", \"date\"], as_index=False).agg(count_day=(\"count\", \"sum\"),\n",
    "                                                                       precip_day=(\"precip_quantity\", \"sum\"),\n",
    "                                                                       rain_share=(\"rain\", \"mean\"),\n",
    "                                                                       heavy_rain_share=(\"heavy_rain\", \"mean\"),\n",
    "                                                                       temp_day=(\"temp_dry_shelter_avg\", \"mean\"),\n",
    "                                                                       wind_day=(\"wind_speed_10m\", \"mean\"),\n",
    "                                                                       gust_day=(\"wind_gusts_speed\", \"mean\"),\n",
    "                                                                       humidity_day=(\"humidity_rel_shelter_avg\",\n",
    "                                                                                     \"mean\"),\n",
    "                                                                       radiation_day=(\"short_wave_from_sky_avg\",\n",
    "                                                                                      \"mean\"),\n",
    "                                                                       weekend=(\"weekend\", \"max\"),\n",
    "                                                                       month=(\"month\", \"first\"),\n",
    "                                                                       nearest_station_km=(\"nearest_station_km\",\n",
    "                                                                                           \"mean\"),\n",
    "                                                                       site_lat=(\"site_lat\", \"mean\"),\n",
    "                                                                       site_lon=(\"site_lon\", \"mean\")))\n",
    "\n",
    "site_day[\"log_count_day\"] = np.log1p(site_day[\"count_day\"])\n",
    "site_day[\"rain_day\"] = (site_day[\"precip_day\"] > 0).astype(int)\n",
    "site_day[\"heavy_rain_day\"] = (site_day[\"precip_day\"] >= 5).astype(int)\n",
    "site_day[\"month\"] = site_day[\"month\"].astype(\"category\")\n",
    "\n",
    "display(site_day.head())\n",
    "display(site_day.shape)\n"
   ]
  },
