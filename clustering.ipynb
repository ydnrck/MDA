    "\n",
    "plot_k3 = pd.DataFrame({\"PC1\": X_pca2[:, 0], \"PC2\": X_pca2[:, 1], \"cluster_k3\": labels_k3})\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.scatterplot(\n",
