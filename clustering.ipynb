   "source": [
    "# making properly formatted time/weather variables\n",
    "\n",
    "site_time[\"ts\"] = pd.to_datetime(site_time[\"ts\"], utc=True)\n",
    "site_time[\"date\"] = site_time[\"ts\"].dt.date\n",
    "site_time[\"hour\"] = site_time[\"ts\"].dt.hour\n",
    "site_time[\"weekday\"] = site_time[\"ts\"].dt.weekday\n",
    "site_time[\"weekend\"] = site_time[\"weekday\"].isin([5, 6]).astype(int)\n",
    "site_time[\"month\"] = site_time[\"ts\"].dt.month\n",
    "site_time[\"rain\"] = (site_time[\"precip_quantity\"] > 0).astype(int)\n",
    "site_time[\"heavy_rain\"] = (site_time[\"precip_quantity\"] >= 1).astype(int)\n",
    "site_time[\"commute_hour\"] = site_time[\"hour\"].isin([7, 8, 16, 17, 18]).astype(int)\n",
    "site_time[\"log_count\"] = np.log1p(site_time[\"count\"])\n",
    "\n",
    "display(site_time.head())"
   ]
  },
