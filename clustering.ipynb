   "source": [
    "# MAIN k-means clustering solution (k=3 on first 5 principal components)\n",
    "\n",
    "\n",
    "pca5 = PCA(n_components=5, random_state=RANDOM_STATE)\n",
    "X_pca5 = pca5.fit_transform(X_clust)\n",
    "\n",
    "km3 = KMeans(n_clusters=3, init=\"k-means++\", n_init=50, max_iter=300, random_state=RANDOM_STATE)\n",
    "\n",
    "labels_raw = km3.fit_predict(X_pca5) + 1\n",
    "label_order = (pd.DataFrame(X_clust, columns=features, index=ids_clust).assign(cluster=labels_raw).groupby(\"cluster\")[\n",
    "                   \"rain_coef\"].mean().sort_values(ascending=False).index)\n",
    "\n",
    "label_map = {old: new for new, old in enumerate(label_order, 1)}\n",
    "\n",
    "labels_k3 = pd.Series(labels_raw).map(label_map).to_numpy()\n",
    "\n",
    "cluster_df = cluster_df.drop(\n",
    "    columns=[\"cluster_k3\", \"silhouette_k3\", \"cluster_k3_x\", \"cluster_k3_y\", \"silhouette_k3_x\", \"silhouette_k3_y\"],\n",
    "    errors=\"ignore\")\n",
    "\n",
    "cluster_df = cluster_df.merge(\n",
    "    pd.DataFrame(\n",
    "        {\"site_id\": ids_clust, \"cluster_k3\": labels_k3, \"silhouette_k3\": silhouette_samples(X_pca5, labels_k3)}),\n",
    "    on=\"site_id\", how=\"left\")\n",
    "\n",
    "cluster_df[\"cluster_k3\"] = cluster_df[\"cluster_k3\"].fillna(0).astype(int)\n",
    "\n",
    "display(cluster_df[\"cluster_k3\"].value_counts().sort_index())\n",
    "\n",
    "print(\"Explained variance retained:\", round(pca5.explained_variance_ratio_.sum(), 3))\n",
    "print(\"Average silhouette:\", round(silhouette_score(X_pca5, labels_k3), 3))\n"
   ]
  },
