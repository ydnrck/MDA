   "source": [
    "# making a final table for clustering\n",
    "\n",
    "cluster_base = site_features.copy()\n",
    "\n",
    "cluster_base[\"log_median_count_day\"] = np.log1p(cluster_base[\"median_count_day\"])\n",
    "\n",
    "candidate_features = [\"rain_coef\", \"precip_coef\", \"heavy_rain_coef\", \"temp_coef\", \"gust_coef\", \"weekend_coef\",\n",
    "                      \"log_median_count_day\", \"rain_share\", \"heavy_rain_share\"]\n",
    "\n",
    "features = [c for c in candidate_features if c in cluster_base.columns]\n",
    "\n",
    "cluster_df = cluster_base[[\"site_id\"] + features + [\"nearest_station_km\", \"mean_count_day\", \"median_count_day\"]].copy()\n",
    "cluster_df = cluster_df.drop_duplicates(subset=\"site_id\")\n",
    "cluster_df = cluster_df.dropna(subset=[\"site_id\"])\n",
    "cluster_df[\"site_id\"] = cluster_df[\"site_id\"].astype(int)\n",
    "\n",
    "display(cluster_df.head())\n",
    "display(cluster_df[features].describe().T)\n"
   ]
  },
