   "source": [
    "# ridge regression coefficents for clustering\n",
    "\n",
    "reg_rows = []\n",
    "\n",
    "for sid, g in site_day.groupby(\"site_id\"):\n",
    "    if g[\"rain_day\"].nunique() < 2:\n",
    "        continue\n",
    "\n",
    "    X_site = pd.get_dummies(\n",
    "        g[[\"precip_day\", \"rain_day\", \"heavy_rain_day\", \"temp_day\", \"wind_day\", \"gust_day\", \"weekend\", \"month\"]],\n",
    "        columns=[\"month\"], drop_first=True)\n",
    "    X_site = X_site.dropna(axis=1, how=\"all\")\n",
    "    y_site = g[\"log_count_day\"]\n",
    "\n",
    "    model = Pipeline(\n",
    "        [(\"imputer\", SimpleImputer(strategy=\"median\")), (\"scaler\", StandardScaler()), (\"regressor\", Ridge(alpha=1.0))])\n",
    "\n",
    "    model.fit(X_site, y_site)\n",
    "\n",
    "    coef = model.named_steps[\"regressor\"].coef_\n",
    "    names = list(X_site.columns)\n",
    "    coef_dict = dict(zip(names, coef))\n",
    "\n",
    "    reg_rows.append({\"site_id\": sid, \"rain_coef\": coef_dict.get(\"rain_day\", np.nan),\n",
    "                     \"precip_coef\": coef_dict.get(\"precip_day\", np.nan),\n",
    "                     \"heavy_rain_coef\": coef_dict.get(\"heavy_rain_day\", np.nan),\n",
    "                     \"temp_coef\": coef_dict.get(\"temp_day\", np.nan), \"wind_coef\": coef_dict.get(\"wind_day\", np.nan),\n",
    "                     \"gust_coef\": coef_dict.get(\"gust_day\", np.nan), \"weekend_coef\": coef_dict.get(\"weekend\", np.nan),\n",
    "                     \"n_days\": len(g), \"mean_count_day\": g[\"count_day\"].mean(),\n",
    "                     \"median_count_day\": g[\"count_day\"].median(), \"rain_share\": g[\"rain_day\"].mean(),\n",
    "                     \"heavy_rain_share\": g[\"heavy_rain_day\"].mean(),\n",
    "                     \"nearest_station_km\": g[\"nearest_station_km\"].mean(), \"site_lat\": g[\"site_lat\"].mean(),\n",
    "                     \"site_lon\": g[\"site_lon\"].mean()})\n",
    "\n",
    "site_features = pd.DataFrame(reg_rows)\n",
    "display(site_features.head())\n",
    "display(site_features.shape)\n",
    "display(site_features.isna().mean().round(3))\n"
   ]
  },
