   "source": [
    "# feature matrix from the table\n",
    "\n",
    "X_raw = cluster_df[features]\n",
    "site_ids = cluster_df[\"site_id\"].to_numpy()\n",
    "\n",
    "preprocess = Pipeline([(\"imputer\", SimpleImputer(strategy=\"median\")), (\"scaler\", StandardScaler())])\n",
    "\n",
    "X = preprocess.fit_transform(X_raw)\n",
    "X = pd.DataFrame(X, columns=features, index=site_ids)\n",
    "\n",
    "display(X.head())\n",
    "display(X.describe().T.round(3))"
   ]
